# ── Supabase ────────────────────────────────────────────────────────────────
# Find these in your Supabase project → Settings → API

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# WARNING: Never expose this to the browser. Server-side only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App ──────────────────────────────────────────────────────────────────────
# Used to build deep-link URLs in API responses (no trailing slash)
VITE_APP_URL=https://your-app.vercel.app

# ── AI (Anthropic) ───────────────────────────────────────────────────────────
# Used by /api/generate for Java & Ruby framework version lookup
ANTHROPIC_API_KEY=sk-ant-...

# ── Email ────────────────────────────────────────────────────────────────────
# Invitation emails are sent via Supabase Auth (admin.inviteUserByEmail).
# No extra config needed here — configure SMTP in your Supabase project:
#   Authentication → SMTP Settings (or use Supabase's built-in email on free tier)
